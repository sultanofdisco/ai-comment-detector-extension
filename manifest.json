{
  "manifest_version": 3,
  "name": "X-AI 댓글 탐지기",
  "version": "1.0.0",
  "description": "자체 AI 모델을 통해 X(트위터) 댓글의 AI 생성 여부를 판별하고 차단합니다.",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content/content-script.js"
      ],
      "css": [
        "content/injector.css"
      ]
    }
  ],
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AI 댓글 탐지기 열기"
  }
}